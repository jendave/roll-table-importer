<form class="rtu-form">

  <fieldset class="rtu-group">
    <legend>Foundry Server</legend>
    <div class="rtu-button-row">
      <button type="button" id="foundryFileBtn"><i class="fas fa-file"></i> File</button>
      <button type="button" id="foundryDirBtn"><i class="fas fa-folder-open"></i> Directory</button>
    </div>
    <div class="rtu-status" id="foundryStatus">Nothing selected.</div>
    <input type="hidden" id="foundryFile" name="foundryFile" value="" />
    <input type="hidden" id="foundryDirectory" name="foundryDirectory" value="" />
  </fieldset>

  <fieldset class="rtu-group">
    <legend>Local Computer</legend>
    <div class="rtu-button-row">
      <button type="button" id="localFileBtn"><i class="fas fa-file-upload"></i> File(s)</button>
      <button type="button" id="localDirBtn"><i class="fas fa-folder-plus"></i> Directory</button>
    </div>
    <div class="rtu-status" id="localStatus">Nothing selected.</div>
    <input type="file" id="localFileInput" name="localFileInput" multiple accept=".json,.csv,.txt" hidden />
    <input type="file" id="localDirInput" name="localDirInput" webkitdirectory hidden />
  </fieldset>

  <div class="form-group rtu-paste">
    <textarea id="clipboardInput" name="clipboardInput"
      placeholder="Paste text, JSON, or CSV here — or use the pickers above."></textarea>
  </div>

  <div class="rtu-footer">
    <button type="button" id="importButton"><i class="fas fa-download"></i> Import</button>
  </div>

</form>
